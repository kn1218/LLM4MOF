# Copy this file to .env and fill in your key(s). .env is git-ignored — never commit real keys.

# Active LLM provider: "openai" or "gemini"
LLM_PROVIDER=openai

# API keys (set the one matching LLM_PROVIDER; the other can stay blank)
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Optional universal-lever toggles (defaults shown; uncomment to override) ---
# Accept 0/1/true/false/yes/no/on/off. See config.py for behavior.
# LLM4MOF_STRATIFIED_SAMPLING=1
# LLM4MOF_USE_MEMORY_LEDGER=1
# LLM4MOF_GEOM_MARGIN_MODE=mae
